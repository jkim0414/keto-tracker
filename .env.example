# Neon Postgres - either of these names works (the @neondatabase/serverless lib reads DATABASE_URL)
DATABASE_URL=postgres://user:password@host/dbname?sslmode=require

# Anthropic API key - required for photo and natural-language food parsing
ANTHROPIC_API_KEY=sk-ant-...

# USDA FoodData Central API key - powers the generic-food autocomplete.
# Free signup at https://fdc.nal.usda.gov/api-key-signup.html (no credit card,
# instant key by email, unlimited usage). Falls back to "DEMO_KEY" if unset,
# but that's rate-limited to ~30 requests/hour.
USDA_FDC_API_KEY=
